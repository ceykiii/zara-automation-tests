# =============================================================================
# Zara E2E Selenium Framework — Local Environment Configuration
# DO NOT commit this file. See .env.example for the template.
# =============================================================================

# --- Application ---
BASE_URL=https://www.zara.com/tr/
APP_ENV=test

# --- Browser ---
BROWSER=chrome
BROWSER_HEADLESS=false
BROWSER_LOCALE=tr-TR
BROWSER_WINDOW_SIZE=1920,1080

# --- Timeouts (seconds) ---
IMPLICIT_WAIT_SECONDS=10
EXPLICIT_WAIT_SECONDS=15
CONDITION_WAIT_SECONDS=15
DISMISS_WAIT_SECONDS=2
PAGE_LOAD_TIMEOUT_SECONDS=30
FLUENT_WAIT_TIMEOUT_SECONDS=20
FLUENT_WAIT_POLLING_MS=500

# --- Test Credentials (use a dedicated test account) ---
TEST_USER_EMAIL=xxxxx@gmail.com
TEST_USER_PASSWORD=xxxxxx

# --- Paths ---
SCREENSHOT_DIR=target/screenshots
TEST_OUTPUT_DIR=src/test/resources/test-data
TEST_DATA_FILE=src/test/resources/test-data/search-terms.xlsx

# --- Cookie ---
COOKIE_DOMAIN=.zara.com

# --- Reporting ---
SCREENSHOT_ON_FAILURE=true

# --- Retry ---
MAX_RETRY_COUNT=2
